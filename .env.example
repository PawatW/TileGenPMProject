# Copy this file to .env and fill in the values

# PostgreSQL password (used by both postgres and backend services)
POSTGRES_PASSWORD=studiopm

# JWT signing secret — change to a long random string in production
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret

# OpenRouter API key (required for AI image-edit feature)
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: AI model override
# OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview

# Flask environment
FLASK_ENV=production

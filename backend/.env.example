# PostgreSQL connection string
DATABASE_URL=postgresql://studiopm:studiopm@postgres:5432/studiopm

# JWT signing secret – change this to a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# OpenRouter API key (required for AI image-edit feature)
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: override the AI model used for image editing
# OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview

FLASK_ENV=production
